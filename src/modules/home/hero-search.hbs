<section class="hero-search">
  <div class="hero-search__container">
    <div class="hero-search__content">
      <h1 class="hero-search__title">Ближе к событиям</h1>
      <p class="hero-search__subtitle">
        Концерты, кино, фестивали и спорт<br />
        все в одном месте
      </p>

      <div class="hero-search__form-wrap" data-role="header-search-wrap">
        <form class="hero-search__form" data-role="hero-search-form">
          <input
            type="text"
            name="query"
            class="hero-search__input"
            placeholder="Найти события"
            value="{{query}}"
          />
          <button class="hero-search__button" type="submit" aria-label="Поиск">
            <img src="/public/static/icons/search.svg" alt="" class="hero-search__button-icon" aria-hidden="true" />
          </button>
        </form>
        <div class="site-header__search-suggestions" data-role="header-search-suggestions" hidden></div>
      </div>
    </div>
  </div>
</section>
