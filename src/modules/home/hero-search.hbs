<section class="hero-search">
  <div class="container">
    <div class="hero-content">
      <h1 class="hero-title">Ближе к событиям</h1>
      <p class="hero-subtitle">
        Концерты, кино, фестивали и спорт<br />
        все в одном месте
      </p>

      <form class="search-form" data-role="hero-search-form">
        <input
          type="text"
          name="query"
          class="search-input"
          placeholder="Найти события"
          value="{{query}}"
        />
        <button class="search-button" type="submit" aria-label="Поиск">
          <img src="/public/static/icons/search.svg" alt="" class="search-button-icon" aria-hidden="true" />
        </button>
      </form>
    </div>
  </div>
</section>
