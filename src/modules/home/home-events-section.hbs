<section class="home-events">
  <div class="home-events__container">
    <section class="home-events__content">
      <div class="home-events__head">
        <h2 class="home-events__title">
          Мероприятия, которые стоит посетить
        </h2>
        <a href="/events" class="home-events__link">показать ещё...</a>
      </div>

      <div class="home-events__grid">
        {{#each events}}
          <a href="/events/{{id}}" class="event-card event-card--home">
            <img src="{{imageUrl}}" alt="{{title}}" class="event-card__image" />
            <h3 class="event-card__title">{{title}}</h3>
            <p class="event-card__text">{{dateText}}</p>
            <p class="event-card__text">{{placeText}}</p>
            <div class="event-card__meta">
              {{#each tags}}
                <span class="event-card__tag">{{this}}</span>
              {{/each}}
            </div>
          </a>
        {{/each}}
      </div>
    </section>
  </div>
</section>
