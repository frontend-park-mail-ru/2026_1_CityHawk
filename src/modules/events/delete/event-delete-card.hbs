<section class="event-delete-card">
  <p class="event-delete-card__eyebrow">Подтверждение удаления</p>
  <h1 class="event-delete-card__title">Удалить событие «{{eventTitle}}»?</h1>
  <p class="event-delete-card__text">
    Это действие нельзя отменить.
  </p>
  <div class="event-delete-card__actions">
    <button type="button" class="event-delete-card__confirm" data-action="event-delete-confirm">
      Удалить событие
    </button>
    <a class="event-delete-card__cancel" href="/events/{{eventId}}/edit">
      Вернуться к редактированию
    </a>
  </div>
</section>
