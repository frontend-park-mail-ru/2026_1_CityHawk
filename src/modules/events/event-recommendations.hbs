<section class="event-recommendations">
  <div class="event-recommendations__container">
    <div class="event-recommendations__head">
      <h2 class="event-recommendations__title">Вам может понравиться</h2>
      <a href="/" class="event-recommendations__link">показать ещё...</a>
    </div>

    <div class="event-recommendations__grid">
      {{#each items}}
        <a href="/events/{{id}}" class="event-card event-card--recommendation">
          <img src="{{imageUrl}}" alt="{{title}}" class="event-card__image" />
          <h3 class="event-card__title">{{title}}</h3>
          <p class="event-card__text">{{description}}</p>
          <div class="event-card__meta">
            {{#each tags}}
              <span class="event-card__tag">{{this}}</span>
            {{/each}}
          </div>
        </a>
      {{/each}}
    </div>
  </div>
</section>
