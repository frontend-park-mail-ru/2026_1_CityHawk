<section class="profile__content">
    <div class="profile__wrapper">
        <h1 class="profile__title">Настройки профиля</h1>

        <form class="profile__form" method="post" action="/profile">
            <div class="profile__grid profile__grid--two">
                {{> form-input
                    fieldClass="profile__field"
                    label="Имя"
                    type="text"
                    id="firstName"
                    name="firstName"
                    placeholder="Имя"
                    value=user.firstName
                }}

                {{> form-input
                    fieldClass="profile__field"
                    label="Фамилия"
                    type="text"
                    id="lastName"
                    name="lastName"
                    placeholder="Фамилия"
                    value=user.lastName
                }}
            </div>

            {{> form-input
                fieldClass="profile__field"
                label="Email"
                type="email"
                id="email"
                name="email"
                placeholder="address@service.com"
                value=user.email
            }}

            <div class="profile__grid profile__grid--two">
                {{> form-input
                    fieldClass="profile__field"
                    label="Дата рождения"
                    type="date"
                    id="birthdate"
                    name="birthdate"
                    value=user.birthdate
                }}

                {{> form-select
                    fieldClass="profile__field"
                    label="Город"
                    id="city"
                    name="city"
                    options=user.cityOptions
                }}
            </div>

            <div class="profile__field">
                <label for="preferences">Предпочтения</label>
                <div class="profile__chips-field">
                    <div class="profile__chips">
                        {{#each user.preferences}}
                            <span class="profile__chip">{{this}}</span>
                        {{/each}}
                    </div>

                    <button class="profile__chips-settings" type="button" aria-label="Настроить предпочтения">
                        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <path d="M12 8.5C10.07 8.5 8.5 10.07 8.5 12C8.5 13.93 10.07 15.5 12 15.5C13.93 15.5 15.5 13.93 15.5 12C15.5 10.07 13.93 8.5 12 8.5Z" stroke="currentColor" stroke-width="2"/>
                            <path d="M19.4 15A1.65 1.65 0 0 0 19.73 16.82L19.79 16.88A2 2 0 1 1 16.96 19.71L16.9 19.65A1.65 1.65 0 0 0 15.08 19.32A1.65 1.65 0 0 0 14 20.85V21A2 2 0 1 1 10 21V20.91A1.65 1.65 0 0 0 8.91 19.39A1.65 1.65 0 0 0 7.09 19.72L7.03 19.78A2 2 0 1 1 4.2 16.95L4.26 16.89A1.65 1.65 0 0 0 4.59 15.07A1.65 1.65 0 0 0 3.06 14H3A2 2 0 1 1 3 10H3.09A1.65 1.65 0 0 0 4.61 8.91A1.65 1.65 0 0 0 4.28 7.09L4.22 7.03A2 2 0 1 1 7.05 4.2L7.11 4.26A1.65 1.65 0 0 0 8.93 4.59H9A1.65 1.65 0 0 0 10 3.06V3A2 2 0 1 1 14 3V3.09A1.65 1.65 0 0 0 15.09 4.61A1.65 1.65 0 0 0 16.91 4.28L16.97 4.22A2 2 0 1 1 19.8 7.05L19.74 7.11A1.65 1.65 0 0 0 19.41 8.93V9A1.65 1.65 0 0 0 20.94 10H21A2 2 0 1 1 21 14H20.91A1.65 1.65 0 0 0 19.39 15.09L19.4 15Z" stroke="currentColor" stroke-width="2"/>
                        </svg>
                    </button>
                </div>
            </div>

            <div class="profile__account-actions">
                <a href="/change-password" class="profile__password-link">Изменить пароль</a>
                <button class="profile__logout-link" type="button">Выйти из аккаунта</button>
            </div>

            <div class="profile__actions">
                <button class="profile__button profile__button--secondary" type="reset">Отменить</button>
                <button class="profile__button profile__button--primary" type="submit">Сохранить</button>
            </div>
        </form>
    </div>
</section>
