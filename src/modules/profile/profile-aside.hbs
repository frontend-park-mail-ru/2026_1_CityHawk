<aside class="profile__aside">
    <a href="/" class="profile__aside-close" aria-label="На главную">
        <svg width="454" height="453" viewBox="0 0 454 453" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M441.304 385.652C456.956 401.304 456.956 425.652 441.304 441.304C433.478 449.13 423.913 452.609 413.478 452.609C403.043 452.609 393.478 449.13 385.652 441.304L226.522 282.174L67.3913 441.304C59.5652 449.13 50 452.609 39.5652 452.609C29.1304 452.609 19.5652 449.13 11.7391 441.304C-3.91304 425.652 -3.91304 401.304 11.7391 385.652L170.87 226.522L11.7391 67.3913C-3.91304 51.7391 -3.91304 27.3913 11.7391 11.7391C27.3913 -3.91304 51.7391 -3.91304 67.3913 11.7391L226.522 170.87L385.652 11.7391C401.304 -3.91304 425.652 -3.91304 441.304 11.7391C456.956 27.3913 456.956 51.7391 441.304 67.3913L282.174 226.522L441.304 385.652Z" fill="currentColor"/>
        </svg>
    </a>

    <a href="/" class="profile__branding" aria-label="CityHawk">
        <span class="profile__logo"></span>
        <span class="profile__brand-name">CityHawk</span>
    </a>

    <div class="profile__user-card">
        <div class="profile__avatar-wrapper">
            {{#if user.avatarUrl}}
            <img
                class="profile__avatar"
                src="{{user.avatarUrl}}"
                alt="Аватар пользователя"
            >
            {{else}}
            <div class="profile__avatar profile__avatar--fallback" aria-label="Аватар пользователя">
                <span class="profile__avatar-initials">{{user.initials}}</span>
            </div>
            {{/if}}
            <button class="profile__avatar-edit" type="button" aria-label="Изменить фото">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 16.25V20H7.75L18.81 8.94L15.06 5.19L4 16.25Z" fill="currentColor"/>
                    <path d="M20.71 7.04C21.1 6.65 21.1 6.02 20.71 5.63L18.37 3.29C17.98 2.9 17.35 2.9 16.96 3.29L15.13 5.12L18.88 8.87L20.71 7.04Z" fill="currentColor"/>
                </svg>
            </button>
        </div>

        <h2 class="profile__user-name">{{user.name}}</h2>
    </div>

    <nav class="profile__menu" aria-label="Меню профиля">
        <a href="/profile" class="profile__menu-item profile__menu-item--active">
            <span class="profile__menu-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 12C14.7614 12 17 9.76142 17 7C17 4.23858 14.7614 2 12 2C9.23858 2 7 4.23858 7 7C7 9.76142 9.23858 12 12 12Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M4 21C4 17.6863 7.58172 15 12 15C16.4183 15 20 17.6863 20 21" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            <span>Настройки профиля</span>
        </a>

        <a href="/events/my" class="profile__menu-item">
            <span class="profile__menu-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M4 7.5C4 6.11929 5.11929 5 6.5 5H17.5C18.8807 5 20 6.11929 20 7.5V16.5C20 17.8807 18.8807 19 17.5 19H6.5C5.11929 19 4 17.8807 4 16.5V7.5Z" stroke="currentColor" stroke-width="2"/>
                    <path d="M8 9H16" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M8 13H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            <span>Мои события</span>
        </a>

        <a href="/favorites" class="profile__menu-item">
            <span class="profile__menu-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M12 20.5L10.55 19.18C5.4 14.5 2 11.41 2 7.5C2 4.42 4.42 2 7.5 2C9.24 2 10.91 2.81 12 4.09C13.09 2.81 14.76 2 16.5 2C19.58 2 22 4.42 22 7.5C22 11.41 18.6 14.5 13.45 19.19L12 20.5Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                </svg>
            </span>
            <span>Избранное</span>
        </a>

        <a href="/logout" class="profile__menu-item">
            <span class="profile__menu-icon">
                <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                    <path d="M10 17L15 12L10 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M15 12H3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                    <path d="M13 4H18C19.1046 4 20 4.89543 20 6V18C20 19.1046 19.1046 20 18 20H13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </span>
            <span>Выйти</span>
        </a>
    </nav>
</aside>
