<div class="{{fieldClass}} form-field">
    <label class="form-field__label{{#if labelClass}} {{labelClass}}{{/if}}" for="{{id}}">{{label}}</label>
    {{#if wrapperClass}}<div class="{{wrapperClass}} form-field__control">{{else}}<div class="form-field__control">{{/if}}
        {{#if inputWrapperClass}}<div class="{{inputWrapperClass}} form-field__input-wrap">{{else}}<div class="form-field__input-wrap">{{/if}}
            <input
                type="{{type}}"
                id="{{id}}"
                name="{{name}}"
                placeholder="{{placeholder}}"
                value="{{value}}"
                class="form-field__input{{#if inputClass}} {{inputClass}}{{/if}}"
            >
            {{#if toggle}}
            <button class="form-field__toggle{{#if toggleClass}} {{toggleClass}}{{/if}}" type="button" aria-label="{{toggleAriaLabel}}">
                <svg class="eye-icon" width="45" height="33">
                    <use href="#eye-open"></use>
                </svg>
            </button>
            {{/if}}
        </div>
        {{#if errorClass}}<p class="form-field__error {{errorClass}}">{{errorMessage}}</p>{{/if}}
    </div>
    {{#if hintLinkHref}}<a href="{{hintLinkHref}}" class="{{hintLinkClass}}">{{hintLinkText}}</a>{{/if}}
</div>
