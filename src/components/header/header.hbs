<div class="site-header">
  <div class="site-header__container">
    <div class="site-header__row">
      <a href="/" class="site-header__brand" aria-label="CityHawk">
        <span class="site-header__brand-mark" aria-hidden="true"></span>
        <span class="site-header__brand-text">CityHawk</span>
      </a>

      <div class="site-header__main">
        <a href="#" class="site-header__link site-header__link--with-icon">
          <img src="/public/static/icons/location.svg" alt="" class="site-header__link-icon" aria-hidden="true" />
          <span>Москва</span>
        </a>

        {{#if headerSearch}}
          <div class="site-header__search-wrap" data-role="header-search-wrap">
            <form class="site-header__search" data-role="header-search-form">
              <input
                type="text"
                name="query"
                class="site-header__search-input"
                placeholder="Найти события"
                value="{{headerSearch.query}}"
                autocomplete="off"
              />
              <button class="site-header__search-button" type="submit" aria-label="Поиск">
                <img src="/public/static/icons/search.svg" alt="" class="site-header__search-icon" aria-hidden="true" />
              </button>
            </form>
            <div
              class="site-header__search-suggestions"
              data-role="header-search-suggestions"
              hidden
            ></div>
          </div>
        {{/if}}
      </div>

      <div class="site-header__actions">
        {{#if user}}
          <a href="/profile" class="site-header__link site-header__link--with-icon site-header__user">
            <img src="/public/static/icons/person.svg" alt="" class="site-header__link-icon" aria-hidden="true" />
            <span>{{user.displayName}}</span>
          </a>
        {{else}}
          <a href="/login" class="site-header__signin">Войти</a>
        {{/if}}
      </div>
    </div>
  </div>
</div>
