{{#if id}}
  <a href="/events/{{id}}" class="event-card {{cardClass}}">
    <img src="{{imageUrl}}" alt="{{title}}" class="event-card__image" />
    <h3 class="event-card__title">{{title}}</h3>

    {{#each textLines}}
      <p class="event-card__text">{{this}}</p>
    {{/each}}

    {{#if tags.length}}
      <div class="event-card__meta">
        {{#each tags}}
          <span class="event-card__tag">{{this}}</span>
        {{/each}}
      </div>
    {{/if}}
  </a>
{{else}}
  <div class="event-card {{cardClass}}">
    <img src="{{imageUrl}}" alt="{{title}}" class="event-card__image" />
    <h3 class="event-card__title">{{title}}</h3>

    {{#each textLines}}
      <p class="event-card__text">{{this}}</p>
    {{/each}}

    {{#if tags.length}}
      <div class="event-card__meta">
        {{#each tags}}
          <span class="event-card__tag">{{this}}</span>
        {{/each}}
      </div>
    {{/if}}
  </div>
{{/if}}
