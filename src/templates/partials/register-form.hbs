<div class="login__form">
  <div class="login__wrapper">
    <h2 class="login__form-title">Регистрация</h2>

    <form id="register-form" class="login__fields">
      <div class="login__field">
        <label for="name">Имя</label>
        <input type="text" id="name" name="name" placeholder="Введите имя" />
      </div>

      <div class="login__field login__email">
        <label for="register-email">Email</label>
        <input type="email" id="register-email" name="email" placeholder="Введите email" />
      </div>

      <div class="login__field login__password">
        <label for="register-password">Пароль</label>
        <input type="password" id="register-password" name="password" placeholder="Введите пароль" />
        <button class="login__password-toggle" type="button" aria-label="Показать пароль">
          <img src="/public/static/assets/eye.svg" alt="" />
        </button>
      </div>

      <div class="login__field login__password">
        <label for="register-password-repeat">Повторите пароль</label>
        <input
          type="password"
          id="register-password-repeat"
          name="passwordRepeat"
          placeholder="Повторите пароль"
        />
        <button class="login__password-toggle" type="button" aria-label="Показать пароль">
          <img src="/public/static/assets/eye.svg" alt="" />
        </button>
      </div>

      <button class="login__submit" type="submit">Зарегистрироваться</button>

      <div class="login__oauth">
        <div class="login__divider">
          <p class="login__divider-text">или</p>
        </div>

        <div class="login__oauth-buttons">
          <div class="login__oauth-wrapper login__oauth-wrapper--yandex">
            <button class="login__oauth-btn login__oauth-btn--yandex" aria-label="Регистрация через Яндекс"></button>
          </div>

          <div class="login__oauth-wrapper login__oauth-wrapper--google">
            <button class="login__oauth-btn login__oauth-btn--google" aria-label="Регистрация через Google"></button>
          </div>

          <div class="login__oauth-wrapper login__oauth-wrapper--vk">
            <button class="login__oauth-btn login__oauth-btn--vk" aria-label="Регистрация через VK"></button>
          </div>
        </div>

        <a href="/login" class="login__register">Уже есть аккаунт?</a>
      </div>
    </form>
  </div>
</div>
