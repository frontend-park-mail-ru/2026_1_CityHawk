<div class="login__form">
    <a href="/" class="login__close" aria-label="На главную">
        <img src="/public/static/assets/cross.svg" alt="">
    </a>
    <div class="login__wrapper">
        <h2 class="login__form-title">Вход</h2>
        <div class="login__fields">
            <div class="login__field login__email">
                <label for="email">Email</label>
                <div class="login__field-error-wrapper">
                    <div class="login__field-icon-wrapper login__field-icon-wrapper-noicon">
                        <input type="email" id="email" name="email" placeholder="Введите email">
                    </div>
                    <p class="login__error-message"></p>
                </div>
            </div>
            <div class="login__field login__password">
                <label for="password">Пароль</label>
                <div class="login__field-error-wrapper">
                    <div class="login__field-icon-wrapper">
                        <input type="password" id="password" name="password" placeholder="Введите пароль">
                        <button class="login__password-toggle" type="button" aria-label="Показать пароль">
                            <img src="/public/static/assets/eye.svg" alt="">
                        </button>
                    </div>
                    <p class="login__error-message"></p>
                </div>
                <a href="/forgot-password" class="login__forgot">Забыли пароль?</a>
            </div>
            <button class="login__submit" type="submit">Войти</button>
            <div class="login__oauth">
                <div class="login__divider">
                    <p class="login__divider-text">или</p>
                </div>
                <div class="login__oauth-buttons">
                    <div class="login__oauth-wrapper login__oauth-wrapper--yandex">
                        <button class="login__oauth-btn login__oauth-btn--yandex" aria-label="Войти через Яндекс"></button>
                    </div>
                    <div class="login__oauth-wrapper login__oauth-wrapper--vk">
                        <button class="login__oauth-btn login__oauth-btn--vk" aria-label="Войти через VK"></button>
                    </div>
                    <div class="login__oauth-wrapper login__oauth-wrapper--google">
                        <button class="login__oauth-btn login__oauth-btn--google" aria-label="Войти через Google"></button>
                    </div>
                </div>
                <a href="/register" class="login__register">Еще нет аккаунта?</a>
            </div>
        </div>
    </div>
</div>
